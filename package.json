{
  "name": "doer-agent",
  "version": "0.6.3",
  "description": "Reverse-polling agent runtime for doer",
  "type": "module",
  "main": "dist/agent.js",
  "bin": {
    "doer-agent": "dist/cli.js",
    "codex": "dist/codex-cli.js"
  },
  "files": [
    "dist",
    "runtime",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js dist/codex-cli.js",
    "start": "node --import tsx src/agent.ts",
    "start:dist": "node dist/agent.js",
    "codex": "codex",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex": "^0.129.0",
    "@openai/codex-sdk": "^0.129.0",
    "nats": "^2.29.3",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
